# SMTP Configuration (required for intake handoff email sending)
# Local MailHog test setup example:
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_SECURE=0
# SMTP_USER=dev
# SMTP_PASS=dev
# SMTP_FROM="GoldyQuote Dev <dev@localhost>"
# HANDOFF_EMAIL_TO=micahp@utexas.edu
#
# Gmail setup example (requires app password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=your-gmail-account@gmail.com
# SMTP_PASS=your-gmail-app-password
# SMTP_FROM="GoldyQuote Intake <your-gmail-account@gmail.com>"
# HANDOFF_EMAIL_TO=micahp@utexas.edu
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=0
